.creator-page {
  padding: 28rpx;
}

.editor {
  padding: 24rpx;
}

.label {
  font-size: 24rpx;
  opacity: 0.8;
}

.map-mock {
  height: 320rpx;
  margin: 16rpx 0 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(100, 193, 255, 0.2), rgba(101, 113, 255, 0.2));
  position: relative;
}

.dot {
  width: 26rpx;
  height: 26rpx;
  border-radius: 50%;
  background: #94efff;
  position: absolute;
}

.dot-1 {
  top: 60rpx;
  left: 80rpx;
}

.dot-2 {
  top: 180rpx;
  left: 280rpx;
}

.dot-3 {
  top: 110rpx;
  right: 120rpx;
}

.story-input {
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.25);
  padding: 14rpx;
  box-sizing: border-box;
}

button {
  margin-top: 24rpx;
  border: none;
  color: #fff;
  background: linear-gradient(135deg, #4f80ff, #925cff);
}
