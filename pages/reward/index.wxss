.reward-page {
  padding: 30rpx;
}

.box-stage {
  margin-top: 50rpx;
  height: 500rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  perspective: 1000rpx;
}

.box {
  width: 280rpx;
  height: 280rpx;
  position: relative;
  transform-style: preserve-3d;
  animation: idle-float 2.2s ease-in-out infinite;
}

.box-body,
.box-lid {
  position: absolute;
  left: 0;
  width: 100%;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #4d8aff, #7a47ff);
  box-shadow: 0 16rpx 30rpx rgba(26, 19, 77, 0.35);
}

.box-body {
  bottom: 0;
  height: 170rpx;
}

.box-lid {
  top: 30rpx;
  height: 92rpx;
  transform-origin: 50% 100%;
  transition: transform 0.8s ease;
}

.box-light {
  position: absolute;
  width: 420rpx;
  height: 420rpx;
  left: -70rpx;
  top: -90rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(164, 225, 255, 0.55), rgba(164, 225, 255, 0) 70%);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.box.opened .box-lid {
  transform: rotateX(-118deg) translateY(-20rpx);
}

.box.opened .box-light {
  opacity: 1;
  animation: pulse 1.1s ease-in-out infinite;
}

.reward-pop {
  position: absolute;
  left: 50%;
  top: 110rpx;
  transform: translateX(-50%) translateY(30rpx) scale(0.7);
  opacity: 0;
  width: 260rpx;
  padding: 16rpx;
  text-align: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(123, 210, 255, 0.85), rgba(168, 129, 255, 0.85));
  box-shadow: 0 12rpx 30rpx rgba(19, 12, 65, 0.35);
  transition: all 0.5s ease;
}

.reward-pop.show {
  opacity: 1;
  transform: translateX(-50%) translateY(-110rpx) scale(1);
}

.reward-icon {
  font-size: 44rpx;
}

.reward-name {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.result {
  padding: 30rpx;
  text-align: center;
  opacity: 0;
  transform: translateY(18rpx);
  transition: all 0.4s ease;
}

.result.visible {
  opacity: 1;
  transform: translateY(0);
}

.result-title {
  font-size: 28rpx;
}

.medal {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.coins {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #8ce5ff;
}

button {
  margin-top: 20rpx;
  border: none;
  color: #fff;
  background: linear-gradient(135deg, #4f80ff, #925cff);
}

@keyframes idle-float {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16rpx);
  }
}

@keyframes pulse {
  0%,
  100% {
    transform: scale(0.95);
  }
  50% {
    transform: scale(1.06);
  }
}
