<view class="detail-page" wx:if="{{script}}">
  <image class="cover" src="{{script.cover}}" mode="aspectFill" />
  <view class="header glass-card" style="border-color: {{script.theme.accent}};">
    <view class="title">{{script.title}}</view>
    <view class="subtitle">{{script.subtitle}}</view>
    <view class="meta" style="color: {{script.theme.accent}};">地点：{{destination}} · ¥{{script.price}} / 人</view>
    <view class="intro" wx:if="{{script.worldIntro}}">{{script.worldIntro}}</view>
  </view>

  <block wx:if="{{!isCityWalk}}">
    <view class="section-title">深度测试 · 角色分配</view>
    <view class="quiz-progress">进度 {{currentQuizIndex + 1}} / {{quiz.length}}（已答 {{answeredCount}} 题）</view>
    <view class="quiz-card glass-card" style="background: {{script.theme.surface}};">
      <view class="quiz-title">{{quiz[currentQuizIndex].title}}</view>
      <view class="option-row">
        <view
          class="option {{answers[quiz[currentQuizIndex].id] === optionIndex ? 'active' : ''}}"
          style="{{answers[quiz[currentQuizIndex].id] === optionIndex ? 'border-color:' + script.theme.accent + ';background:' + script.theme.surface + ';' : ''}}"
          wx:for="{{quiz[currentQuizIndex].options}}"
          wx:key="index"
          wx:for-item="option"
          wx:for-index="optionIndex"
          data-qid="{{quiz[currentQuizIndex].id}}"
          data-idx="{{optionIndex}}"
          bindtap="chooseAnswer"
        >
          {{option}}
        </view>
      </view>
      <view class="quiz-nav">
        <button class="btn-secondary" size="mini" bindtap="prevQuiz" disabled="{{currentQuizIndex === 0}}">上一题</button>
        <button class="btn-secondary" size="mini" bindtap="nextQuiz" disabled="{{currentQuizIndex === quiz.length - 1}}">
          下一题
        </button>
      </view>
    </view>
    <view class="actions">
      <button class="btn-secondary" bindtap="assignRole">分配角色</button>
      <button class="btn-primary" bindtap="startGame">开始分章节故事</button>
    </view>
  </block>

  <block wx:if="{{isCityWalk}}">
    <view class="section-title">选择主题宇宙</view>
    <view class="quiz-card glass-card universe-card" wx:for="{{universes}}" wx:key="key" wx:for-item="universe">
      <view class="quiz-title">{{universe.name}}</view>
      <view class="universe-desc">{{universe.desc}}</view>
      <view
        class="pick-btn {{selectedUniverseKey === universe.key ? 'selected' : ''}}"
        data-key="{{universe.key}}"
        bindtap="selectUniverse"
      >
        {{selectedUniverseKey === universe.key ? "已选中" : "选择该宇宙"}}
      </view>
    </view>
    <view class="actions">
      <button class="btn-primary" bindtap="startGame">进入 City Walk 任务</button>
    </view>
  </block>

  <view class="role-mask" wx:if="{{showRoleCard}}" bindtap="closeRole">
    <view class="role-card glass-card" catchtap="noop">
      <view class="role-title">角色解锁</view>
      <view class="role-name">{{role.name}}</view>
      <view class="role-skill">{{role.skill}}</view>
      <view class="role-tip">点击空白区域关闭</view>
    </view>
  </view>
</view>
