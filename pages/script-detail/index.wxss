.detail-page {
  padding: 26rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
}

.header {
  margin-top: -60rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  padding: 24rpx 26rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.85;
}

.meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #9ce7ff;
}

.intro {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.7;
  opacity: 0.85;
}

.quiz-card {
  padding: 22rpx;
  margin-bottom: 18rpx;
}

.quiz-progress {
  margin-bottom: 12rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.quiz-title {
  font-size: 28rpx;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.option {
  min-width: 30%;
  flex: 1 1 30%;
  text-align: center;
  padding: 12rpx 8rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
  font-size: 22rpx;
}

.option.active {
  background: rgba(87, 160, 255, 0.35);
  border-color: rgba(156, 226, 255, 0.8);
}

.quiz-nav {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.actions {
  margin-top: 24rpx;
}

button {
  margin-top: 14rpx;
  border: none;
  color: #fff;
}

.btn-primary {
  background: linear-gradient(135deg, #3e7bff, #8f59ff);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.18);
}

.universe-card {
  margin-bottom: 18rpx;
}

.universe-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  opacity: 0.82;
}

.pick-btn {
  margin-top: 16rpx;
  padding: 14rpx 20rpx;
  text-align: center;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.26);
  font-size: 24rpx;
}

.pick-btn.selected {
  background: rgba(102, 149, 255, 0.35);
  border-color: rgba(171, 233, 255, 0.92);
}

.role-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.role-card {
  width: 560rpx;
  text-align: center;
  padding: 38rpx 30rpx;
  transform-style: preserve-3d;
  animation: flip-in 0.7s ease;
}

.role-title {
  font-size: 24rpx;
  opacity: 0.8;
}

.role-name {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.role-skill {
  margin-top: 20rpx;
  font-size: 24rpx;
}

.role-tip {
  margin-top: 24rpx;
  font-size: 20rpx;
  opacity: 0.65;
}

@keyframes flip-in {
  from {
    opacity: 0;
    transform: rotateY(90deg) scale(0.9);
  }
  to {
    opacity: 1;
    transform: rotateY(0) scale(1);
  }
}
